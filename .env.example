# ── HUSH Environment Variables ─────────────────────────────────────────────────
# Copy to .env and fill in values before running.

# ── Solana RPC ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_RPC_WS_URL=wss://api.devnet.solana.com

# ── Anchor ─────────────────────────────────────────────────────────────────────
ANCHOR_WALLET=~/.config/solana/id.json
ANCHOR_CLUSTER=devnet

# ── MagicBlock ─────────────────────────────────────────────────────────────────
# Cluster: mainnet | devnet
MAGICBLOCK_CLUSTER=devnet

# Base58 private key for the settlement relay wallet.
# This wallet holds USDC in the MagicBlock ephemeral rollup
# and signs settlement transfer transactions server-side.
# Generate: solana-keygen new --no-bip39-passphrase --outfile relay-keypair.json
# Then: cat relay-keypair.json | python3 -c "import json,sys,base58; k=json.load(sys.stdin); print(base58.b58encode(bytes(k)).decode())"
RELAY_PRIVATE_KEY=

# ── Umbra Privacy SDK ──────────────────────────────────────────────────────────
# These are the canonical endpoints — only override for custom deployments.
UMBRA_INDEXER_API=https://utxo-indexer.api.umbraprivacy.com
UMBRA_RELAYER_API=https://relayer.api.umbraprivacy.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
DB_PATH=./data.db
NODE_ENV=development

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_ENV=development
