{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@hush/types": ["packages/types/src/index.ts"],
      "@hush/sdk": ["packages/sdk/src/index.ts"]
    }
  },
  "include": ["tests/**/*.ts", "scripts/**/*.ts"]
}
